# -----------------------------------------------------------------------------
# Cortex
# EditorConfig
#
# Defines the default coding style for the Cortex project.
# Supported by Cursor, VS Code, JetBrains IDEs and many other editors.
# -----------------------------------------------------------------------------

root = true

# -----------------------------------------------------------------------------
# Global Defaults
# -----------------------------------------------------------------------------

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# Markdown
#
# Preserve trailing spaces (used for line breaks in Markdown).
# -----------------------------------------------------------------------------

[*.md]
trim_trailing_whitespace = false

# -----------------------------------------------------------------------------
# Source Code
# -----------------------------------------------------------------------------

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# -----------------------------------------------------------------------------
# JSON
# -----------------------------------------------------------------------------

[*.{json,jsonc}]
indent_size = 2

# -----------------------------------------------------------------------------
# YAML
# -----------------------------------------------------------------------------

[*.{yml,yaml}]
indent_size = 2

# -----------------------------------------------------------------------------
# HTML / CSS
# -----------------------------------------------------------------------------

[*.{html,css,scss}]
indent_size = 2

# -----------------------------------------------------------------------------
# Shell Scripts
# -----------------------------------------------------------------------------

[*.sh]
indent_size = 2

# -----------------------------------------------------------------------------
# GitHub Actions
# -----------------------------------------------------------------------------

[.github/workflows/*]
indent_size = 2

# -----------------------------------------------------------------------------
# Makefiles
# -----------------------------------------------------------------------------

[Makefile]
indent_style = tab
