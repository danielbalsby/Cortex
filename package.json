{
  "name": "cortex",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run typecheck && npm run test && npm run build",
    "check:release": "npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "15.5.18",
    "react": "19.1.7",
    "react-dom": "19.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "typescript": "5.8.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "description": "Clinical workflow platform for Danish general practice."
}
